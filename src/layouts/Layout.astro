---
---
<html>
  <head>
    <title>Junghoon Nam</title>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
      body {
        margin: 0;
        background-color: black;
        color: white;
        font-family: 'Inter', sans-serif;
      }

      header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 60px 120px 20px 120px;
      }

      /* 로고 */
      .logo a {
        text-decoration: none;
        color: white;
      }

      .name {
        font-family: 'Playfair Display', serif;
        font-size: 30px;
        font-weight: 700;
      }

      .composer {
        font-size: 14px;
        letter-spacing: 4px;
        margin-top: 3px;
      }

      /* 메뉴 */
      nav {
        display: flex;
        gap: 40px;
        margin-left: -50px;
        font-size: 17px;
      }

      nav ul {
        list-style: none;
        display: flex;
        gap: 40px;
        margin: 0;
        padding: 0;
      }

      nav li {
        text-transform: uppercase;
      }

      nav a {
        text-decoration: none;
        color: white;
        font-weight: 500;
      }

      nav a:hover {
        opacity: 0.6;
      }

      /* SNS */
      .sns {
        display: flex;
        gap: 22px;
      }

      .sns img {
        height: 24px;
      }

      .sns img:hover {
        opacity: 0.7;
      }

      /* 배경 */
      .center-image {
        display: flex;
        justify-content: center;
        align-items: center;
        height: 75vh;
      }

      .center-image img {
        max-width: 850px;
        width: 90%;
      }

      /* 프로필 */
      .profile-container {
        display: flex;
        gap: 60px;
        max-width: 1000px;
        margin: 80px auto;
        align-items: flex-start;
      }

      .profile-image img {
        width: 300px;
      }

      .profile-text {
        flex: 1;
        font-size: 17px;
        line-height: 1.9;
        color: #ddd;
      }

      main {
        max-width: 1100px;
        margin: 0 auto;
      }
    </style>
  </head>

  <body>

    <header>

      <!-- 로고 -->
      <div class="logo">
        <a href="/">
          <div class="name">Junghoon Nam</div>
          <div class="composer">COMPOSER</div>
        </a>
      </div>

      <!-- 메뉴 (하위메뉴 완전 제거됨) -->
      <nav>
        <ul>
          <li><a href="/about">ABOUT</a></li>
          <li><a href="/works">WORKS</a></li>
          <li><a href="/events">EVENTS</a></li>
          <li><a href="/archive">ARCHIVE</a></li>
          <li><a href="/contact">CONTACT</a></li>
        </ul>
      </nav>

      <!-- SNS -->
      <div class="sns">
        <a href="https://www.instagram.com/junghoon.n/" target="_blank">
          <img src="https://upload.wikimedia.org/wikipedia/commons/a/a5/Instagram_icon.png">
        </a>

        <a href="https://www.facebook.com/junghoon.nam.39" target="_blank">
          <img src="https://upload.wikimedia.org/wikipedia/commons/0/05/Facebook_Logo_%282019%29.png">
        </a>

        <a href="https://www.youtube.com/" target="_blank">
          <img src="https://upload.wikimedia.org/wikipedia/commons/4/42/YouTube_icon_%282013-2017%29.png">
        </a>
      </div>

    </header>

    <div class="center-image">
      <img src="/mybackground.jpg">
    </div>

    <main>
      <slot />
    </main>

  </body>
</html>
